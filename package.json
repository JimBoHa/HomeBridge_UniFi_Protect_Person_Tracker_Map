{
  "name": "homebridge-unifi-protect-person-tracker-map",
  "version": "0.1.0",
  "description": "Homebridge UniFi Protect person tracker map camera overlay.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "unifi",
    "protect",
    "camera"
  ],
  "engines": {
    "node": ">=20.18.1",
    "homebridge": ">=1.8.0 || >=2.0.0"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "prepare": "npm run build",
    "security": "npm audit --audit-level=moderate",
    "verify": "npm run build && npm run lint && npm test && npm run security"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.4",
    "pdfjs-dist": "^4.10.38",
    "pureimage": "0.4.18",
    "undici": "^7.28.0",
    "zod": "4.1.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.4.0",
    "homebridge": "2.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "homebridge": ">=1.8.0 || >=2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
