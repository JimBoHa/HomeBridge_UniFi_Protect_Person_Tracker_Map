{
  "pluginAlias": "UniFiProtectPersonTrackerMap",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Camera Name",
        "type": "string",
        "default": "Person Tracker Map"
      },
      "mapImagePath": {
        "title": "Map Image Path",
        "type": "string",
        "description": "Absolute local path to a PNG/JPEG floor plan or site map."
      },
      "mapImageData": {
        "title": "Uploaded Map Image",
        "type": "string",
        "description": "PNG/JPEG data URL saved by the plugin settings map editor. Uploaded PDFs are rendered to PNG first.",
        "pattern": "^data:image/(png|jpeg);base64,[A-Za-z0-9+/]+={0,2}$"
      },
      "mapConfigPath": {
        "title": "Map Config Path",
        "type": "string",
        "description": "Absolute local path to JSON camera/device placement config."
      },
      "mapConfig": {
        "title": "Map Camera Placements",
        "type": "object",
        "properties": {
          "width": { "type": "integer", "minimum": 1, "maximum": 10000 },
          "height": { "type": "integer", "minimum": 1, "maximum": 10000 },
          "scale": {
            "type": "object",
            "properties": {
              "pixels": { "type": "number", "exclusiveMinimum": 0, "maximum": 10000 },
              "distance": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
              "unit": { "type": "string", "enum": ["ft", "m"] }
            },
            "required": ["pixels", "distance", "unit"]
          },
          "cameras": {
            "type": "array",
            "maxItems": 512,
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "minLength": 1, "maxLength": 128 },
                "name": { "type": "string", "minLength": 1, "maxLength": 128 },
                "position": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number", "minimum": 0 },
                    "y": { "type": "number", "minimum": 0 }
                  },
                  "required": ["x", "y"]
                },
                "headingDegrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
                "fovDegrees": { "type": "number", "minimum": 10, "maximum": 360 }
              },
              "required": ["id", "name", "position"]
            }
          }
        },
        "required": ["width", "height", "cameras"]
      },
      "bindHost": {
        "title": "HTTP Bind Host",
        "type": "string",
        "default": "127.0.0.1"
      },
      "port": {
        "title": "HTTP Port",
        "type": "integer",
        "default": 0,
        "minimum": 0,
        "maximum": 65535
      },
      "adminToken": {
        "title": "Admin Token",
        "type": "string",
        "description": "Required for write endpoints. Leave blank to auto-generate on startup."
      },
      "protect": {
        "title": "UniFi Protect",
        "type": "object",
        "properties": {
          "host": { "type": "string" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "ignoreTls": { "type": "boolean", "default": false },
          "pollSeconds": { "type": "integer", "default": 5, "minimum": 2 }
        }
      },
      "peopleTtlSeconds": {
        "title": "Person TTL Seconds",
        "type": "integer",
        "default": 86400,
        "minimum": 10
      },
      "ffmpegPath": {
        "title": "FFmpeg Path",
        "type": "string",
        "default": "ffmpeg"
      }
    },
    "required": ["name"]
  }
}
